<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>QC Lost and Found Ticket Management System</display-name>

    <!-- General admin login/session filter -->
    <filter>
        <filter-name>AdminAuthFilter</filter-name>
        <filter-class>edu.cs.AdminAuthFilter</filter-class>
    </filter>

    <!-- ADMIN-only role filter -->
    <filter>
        <filter-name>AdminOnlyFilter</filter-name>
        <filter-class>edu.cs.AdminOnlyFilter</filter-class>
    </filter>

    <!-- Protected dashboard -->
    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/AdminDashboardServlet</url-pattern>
    </filter-mapping>

    <!-- Protected ticket pages -->
    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/ViewTicketsServlet</url-pattern>
    </filter-mapping>

    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/TicketDetailsServlet</url-pattern>
    </filter-mapping>

    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/UpdateTicketStatusServlet</url-pattern>
    </filter-mapping>

    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/DeleteTicketServlet</url-pattern>
    </filter-mapping>

    <!-- Protected found item pages -->
    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/ViewFoundItemsServlet</url-pattern>
    </filter-mapping>

    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/AddFoundItemServlet</url-pattern>
    </filter-mapping>

    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/UpdateFoundItemStatusServlet</url-pattern>
    </filter-mapping>

    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/DeleteFoundItemServlet</url-pattern>
    </filter-mapping>

    <!-- Protected matching pages -->
    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/MatchFoundItemServlet</url-pattern>
    </filter-mapping>

    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/MatchItemServlet</url-pattern>
    </filter-mapping>

    <!-- ADMIN-only account management pages -->
    <filter-mapping>
        <filter-name>AdminOnlyFilter</filter-name>
        <url-pattern>/ManageAdminsServlet</url-pattern>
    </filter-mapping>

    <filter-mapping>
        <filter-name>AdminOnlyFilter</filter-name>
        <url-pattern>/CreateAdminServlet</url-pattern>
    </filter-mapping>

    <filter-mapping>
        <filter-name>AdminOnlyFilter</filter-name>
        <url-pattern>/ToggleAdminStatusServlet</url-pattern>
    </filter-mapping>

    <!-- Session expires after 15 minutes of inactivity -->
    <session-config>
        <session-timeout>15</session-timeout>
    </session-config>

</web-app>